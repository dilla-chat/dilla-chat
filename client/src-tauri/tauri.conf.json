{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-docs/main/tauri.conf.json",
  "productName": "Slimcord",
  "version": "0.1.0",
  "identifier": "com.slimcord.desktop",
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Slimcord",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
